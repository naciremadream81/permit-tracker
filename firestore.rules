rules_version = '2';

// Shared team workspace — only the emails listed below get in.
// Edit the list, then deploy: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeamMember() {
      return request.auth != null
        && request.auth.token.email_verified
        && request.auth.token.email in [
          'sdswonger@gmail.com'
          // , 'nancyarmstrong61@gmail.com'
        ];
    }

    match /workspaces/main/{document=**} {
      allow read, write: if isTeamMember();
    }
  }
}
